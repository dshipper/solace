{
  "name": "solace",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 4863",
    "build": "next build",
    "start": "next start -p 4863",
    "seed": "tsx scripts/seed.ts",
    "test": "vitest run --config vitest.config.ts",
    "test:integration": "next build && vitest run --config vitest.integration.config.ts",
    "ios:generate": "xcodegen generate --spec ios/project.yml",
    "ios:build": "xcodebuild -project ios/Solace.xcodeproj -scheme Solace -destination 'platform=iOS Simulator,id=843FA19C-C232-43B0-8E45-7AB39F722CFB' build",
    "ios:test": "xcodebuild test -project ios/Solace.xcodeproj -scheme Solace -destination 'platform=iOS Simulator,id=843FA19C-C232-43B0-8E45-7AB39F722CFB'"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.0",
    "next": "^15.1.6",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
